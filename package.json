{
  "name": "audio-haxor",
  "version": "1.11.0",
  "description": "Desktop app to scan and manage VST/VST3/AU audio plugins, samples, and DAW projects",
  "scripts": {
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "node --test test/*.test.js && cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "doc": "cargo doc --manifest-path src-tauri/Cargo.toml --no-deps --document-private-items",
    "doc:open": "cargo doc --manifest-path src-tauri/Cargo.toml --no-deps --document-private-items --open",
    "doc:sync": "pnpm run doc && rm -rf docs/api && mkdir -p docs && cp -R src-tauri/target/doc docs/api",
    "clean": "command rm -rf src-tauri/target dist node_modules/.cache && echo 'Cleaned build caches'",
    "bust": "node -e \"const f=require('fs'),p='frontend/index.html';let h=f.readFileSync(p,'utf8');const v=Date.now()%100000;h=h.replace(/\\?v=\\d+/g,'?v='+v);f.writeFileSync(p,h);console.log('Cache busted to v'+v)\"",
    "rebuild": "pnpm run bust && pnpm run clean && pnpm run tauri:build",
    "nuke": "find ~/Library/WebKit/audio-haxor ~/Library/WebKit/com.menketechnologies.audio-haxor ~/Library/Caches/audio-haxor ~/Library/Caches/com.menketechnologies.audio-haxor -delete 2>/dev/null; pnpm run rebuild"
  },
  "keywords": [
    "vst",
    "plugins",
    "audio",
    "updater"
  ],
  "author": {
    "name": "MenkeTechnologies",
    "email": "MenkeTechnologies@gmail.com"
  },
  "license": "ISC",
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2.6.0"
  }
}
