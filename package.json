{
  "name": "audio-haxor",
  "version": "1.16.0",
  "description": "Desktop app to scan and manage VST/VST3/AU audio plugins, samples, and DAW projects",
  "scripts": {
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:ci": "tauri build --ci --no-sign",
    "ship-check": "bash scripts/ship-check.sh",
    "test": "bash scripts/test.sh",
    "test:js": "node scripts/run-js-tests.mjs",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "doc": "cargo doc --manifest-path src-tauri/Cargo.toml --no-deps --document-private-items",
    "doc:open": "cargo doc --manifest-path src-tauri/Cargo.toml --no-deps --document-private-items --open",
    "doc:sync": "pnpm run doc && command rm -rf docs/api && mkdir -p docs && cp -R src-tauri/target/doc docs/api",
    "clean": "bash scripts/clean.sh",
    "bust": "bash scripts/bust.sh",
    "rebuild": "bash scripts/rebuild.sh",
    "nuke": "bash scripts/nuke.sh",
    "deploy": "bash scripts/deploy.sh",
    "db:vacuum": "bash scripts/db-vacuum.sh",
    "db:stats": "bash scripts/db-stats.sh"
  },
  "keywords": [
    "vst",
    "plugins",
    "audio",
    "updater"
  ],
  "author": {
    "name": "MenkeTechnologies",
    "email": "MenkeTechnologies@gmail.com"
  },
  "license": "ISC",
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2.7.0"
  }
}
