{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/crates/tauri-utils/schema.json",
  "productName": "AUDIO_HAXOR",
  "version": "1.18.20",
  "identifier": "com.menketechnologies.audio-haxor",
  "build": {
    "frontendDist": "../frontend",
    "beforeDevCommand": "node scripts/build-audio-engine.mjs",
    "beforeBuildCommand": "node scripts/prepare-audio-engine-audioengine.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AUDIO_HAXOR",
        "width": 2200,
        "height": 1400,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: https://asset.localhost tauri:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost asset: https://asset.localhost tauri:; media-src 'self' asset: https://asset.localhost tauri: blob:; img-src 'self' asset: https://asset.localhost tauri: data: blob:",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "Entitlements.plist",
      "signingIdentity": "-"
    },
    "externalBin": [
      "binaries/audio-engine"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
